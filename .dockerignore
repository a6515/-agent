# ============================================================
# Docker 构建忽略文件
# ============================================================

# ---- 版本控制 ----
.git/
.gitignore

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo

# ---- 前端（仅排除依赖和构建产物，源码供 Dockerfile.nginx 使用）----
frontend/node_modules/
frontend/dist/

# ---- 测试 ----
tests/
.pytest_cache/
.coverage
htmlcov/

# ---- 文档 ----
docs/

# ---- Python 缓存 ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ---- 敏感配置（通过 docker-compose env_file 注入）----
.env
.env.dev
.env.prod

# ---- 数据（通过 volume 挂载）----
data/

# ---- 构建产物 ----
*.tar
*.zip

# ---- OS ----
.DS_Store
Thumbs.db

# ---- 部署文件（仅排除敏感/脚本/文档，保留 nginx.conf 供 Dockerfile.nginx 使用）----
deploy/.env*
deploy/docker-compose.yml
deploy/Dockerfile
deploy/Dockerfile.nginx
deploy/*.ps1
deploy/*.md
