# ============================================================
# 致远 OA 智能公文 AI Agent — 生产环境变量模板
# ============================================================
# 使用方式：
#   cp .env.example .env
#   编辑 .env 填入真实配置
# ============================================================

# ---- LLM 配置（必填）----
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxxxxxxx          # ← 替换为正式的 DeepSeek API Key
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.3

# ---- Embedding 模型（推荐 local，免费离线）----
EMBEDDING_TYPE=local
LOCAL_EMBEDDING_MODEL=/app/models/bge-small-zh-v1.5

# ---- 向量库配置（容器内路径，无需修改）----
RAW_DOCS_DIR=./data/raw_docs
VECTOR_DB_DIR=./data/vector_db
VECTOR_DB_TYPE=chroma
CHROMA_COLLECTION_NAME=oa_official_docs

# ---- 分块与检索参数 ----
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RETRIEVER_K=4

# ---- 服务配置 ----
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=*

# ---- 速率限制 ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERATE=10/minute
RATE_LIMIT_AGENT=5/minute

# ---- Token 追踪 ----
TOKEN_TRACKING_ENABLED=true

# ---- LLM 重试 ----
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY=1.0

# ---- 致远 OA 对接（部署到客户现场后填写）----
SEEYON_OA_BASE_URL=
SEEYON_OA_API_TOKEN=
SEEYON_OA_FORM_ID=
